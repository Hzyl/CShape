<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioGuide.App.Views.MapPage"
             Title="🗺️ Bản Đồ Điểm Du Lịch"
             BackgroundColor="#f5f5f5">

    <Grid RowDefinitions="auto,*,auto" Padding="0" RowSpacing="0">

        <!-- Header: Search Controls -->
        <VerticalStackLayout Padding="15,10" Spacing="10" BackgroundColor="White">
            <Label Text="Tìm kiếm điểm du lịch gần bạn"
                   FontSize="16" FontAttributes="Bold" />

            <!-- Radius Slider -->
            <StackLayout Spacing="5">
                <Label Text="{Binding SearchRadius, StringFormat='Bán kính: {0:F0}m'}"
                       FontSize="12" TextColor="#666" />
                <Slider x:Name="RadiusSlider"
                        Minimum="100" Maximum="50000"
                        Value="{Binding SearchRadius}"
                        ThumbColor="#512BD4" />
            </StackLayout>

            <!-- Status Messages -->
            <Label Text="{Binding LoadingMessage}"
                   FontSize="12" TextColor="#08630b"
                   IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />

            <Label Text="{Binding ErrorMessage}"
                   FontSize="12" TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <!-- Loading Indicator -->
            <StackLayout Orientation="Horizontal" Spacing="10"
                         IsVisible="{Binding IsLoading}">
                <ActivityIndicator IsRunning="True" Color="#512BD4" />
                <Label Text="{Binding LoadingMessage}" VerticalTextAlignment="Center" />
            </StackLayout>
        </VerticalStackLayout>

        <!-- Main Content: POI Map View -->
        <VerticalStackLayout Grid.Row="1" Padding="0" Spacing="0">
            <!-- POI List -->
            <CollectionView ItemsSource="{Binding NearbyPois}"
                           SelectionMode="Single"
                           SelectionChangedCommand="{Binding Path=.}"
                           SelectionChangedCommandParameter="{Binding .}">
                <CollectionView.EmptyView>
                    <StackLayout Padding="20" Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="📍 Không có điểm du lịch"
                               FontSize="16" FontAttributes="Bold" />
                        <Label Text="Nhấn nút tìm kiếm để cập nhật danh sách"
                               FontSize="12" TextColor="#666" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="#512BD4" CornerRadius="10" Padding="12" HasShadow="True">
                            <StackLayout Spacing="8">
                                <!-- POI Name -->
                                <Label Text="{Binding Name}"
                                       FontSize="16" FontAttributes="Bold" />

                                <!-- Distance -->
                                <StackLayout Orientation="Horizontal" Spacing="10">
                                    <Label Text="📏 Khoảng cách:" FontSize="11" />
                                    <Label Text="{Binding DistanceInMeters, StringFormat='{0:F0}m'}"
                                           FontSize="11" TextColor="#512BD4" />
                                </StackLayout>

                                <!-- Trigger Radius -->
                                <StackLayout Orientation="Horizontal" Spacing="10">
                                    <Label Text="🔔 Bán kính GPS:" FontSize="11" />
                                    <Label Text="{Binding TriggerRadius, StringFormat='{0}m'}"
                                           FontSize="11" TextColor="#666" />
                                </StackLayout>

                                <!-- Languages Available -->
                                <StackLayout Orientation="Horizontal" Spacing="10">
                                    <Label Text="🌍 Ngôn ngữ:" FontSize="11" />
                                    <Label Text="{Binding AvailableLanguagesCount, StringFormat='{0} thứ'}"
                                           FontSize="11" TextColor="#666" />
                                </StackLayout>

                                <!-- Priority Badge -->
                                <StackLayout Orientation="Horizontal" Spacing="10">
                                    <Label Text="⭐ Mức ưu tiên:" FontSize="11" />
                                    <Label Text="{Binding Priority, StringFormat='{0}/10'}"
                                           FontSize="11" FontAttributes="Bold" TextColor="#ff9500" />
                                </StackLayout>

                                <!-- Image (if available) -->
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFill" HeightRequest="150"
                                       CornerRadius="8"
                                       IsVisible="{Binding ImageUrl, Converter={StaticResource NullToBoolConverter}}" />
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Footer: Action Buttons -->
        <StackLayout Grid.Row="2" Padding="15" Spacing="10" BackgroundColor="White">
            <!-- Statistics -->
            <Label Text="{Binding PoiCount, StringFormat='Tìm thấy {0} điểm du lịch'}"
                   FontSize="12" TextColor="#666" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Search Button -->
                <Button Text="🔍 Tìm Kiếm"
                        Command="{Binding SearchNearbyPoisCommand}"
                        BackgroundColor="#512BD4" TextColor="White"
                        Grid.Column="0" CornerRadius="10" Padding="10" />

                <!-- Refresh Button -->
                <Button Text="🔄 Làm Mới"
                        Command="{Binding RefreshCommand}"
                        BackgroundColor="#17a2b8" TextColor="White"
                        Grid.Column="1" CornerRadius="10" Padding="10" />
            </Grid>

            <!-- Geofencing Status -->
            <StackLayout Orientation="Horizontal" Spacing="10" Padding="10"
                        BackgroundColor="{Binding IsGeofencingActive, Converter={StaticResource BoolToColorConverter}}">
                <Label Text="{Binding IsGeofencingActive, StringFormat='{0:f}'}"
                       FontSize="20" />
                <Label Text="{Binding IsGeofencingActive, StringFormat='{0, Converter=...}'}"
                       FontSize="12" VerticalTextAlignment="Center" />
            </StackLayout>
        </StackLayout>
    </Grid>
</ContentPage>
