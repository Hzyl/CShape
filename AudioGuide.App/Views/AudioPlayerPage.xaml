<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioGuide.App.Views.AudioPlayerPage"
             Title="🎵 Trình Phát Audio"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <!-- Current Audio Info -->
            <Frame BorderColor="#512BD4" CornerRadius="15" Padding="15" HasShadow="True">
                <StackLayout Spacing="12">
                    <!-- Album Art Placeholder -->
                    <Frame BorderColor="#e0e0e0" CornerRadius="100" Padding="0"
                          HeightRequest="200" WidthRequest="200"
                          HorizontalOptions="Center">
                        <Label Text="🎵" FontSize="80" VerticalTextAlignment="Center"
                              HorizontalTextAlignment="Center" />
                    </Frame>

                    <!-- Current POI Name -->
                    <Label Text="{Binding CurrentPoiName}"
                           FontSize="18" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />

                    <!-- Playback Time Info -->
                    <Label Text="{Binding PlaybackTimeDisplay}"
                           FontSize="13" TextColor="#666"
                           HorizontalTextAlignment="Center" FontFamily="Courier" />
                </StackLayout>
            </Frame>

            <!-- Progress Bar -->
            <StackLayout Spacing="8">
                <Slider x:Name="ProgressSlider"
                        Minimum="0" Maximum="1"
                        Value="{Binding PlaybackProgress}"
                        ThumbColor="#512BD4" />
                <Label Text="{Binding PlaybackTimeDisplay}"
                       FontSize="11" TextColor="#666" HorizontalTextAlignment="Center" />
            </StackLayout>

            <!-- Playback Controls -->
            <StackLayout Orientation="Horizontal" Spacing="10" HorizontalOptions="Center">
                <!-- Previous Button -->
                <Button Text="⏮" FontSize="20"
                        BackgroundColor="#6c757d" TextColor="White"
                        WidthRequest="50" HeightRequest="50"
                        CornerRadius="25" Padding="0" />

                <!-- Play/Pause Button (Large) -->
                <Button Text="{Binding IsPlaying, StringFormat='{0}'}"
                        Command="{Binding PlayPauseCommand}"
                        BackgroundColor="#512BD4" TextColor="White"
                        WidthRequest="70" HeightRequest="70"
                        CornerRadius="35" Padding="0"
                        FontSize="30" />

                <!-- Next Button -->
                <Button Text="⏭" FontSize="20"
                        Command="{Binding SkipToNextCommand}"
                        BackgroundColor="#512BD4" TextColor="White"
                        WidthRequest="50" HeightRequest="50"
                        CornerRadius="25" Padding="0" />
            </StackLayout>

            <!-- Queue Count Info -->
            <Label Text="{Binding QueueCount, StringFormat='📂 Hàng đợi: {0} thuyết minh'}"
                   FontSize="12" TextColor="#666"
                   HorizontalTextAlignment="Center" />

            <!-- Error Message -->
            <Frame BorderColor="#dc3545" CornerRadius="10" Padding="12"
                   HasShadow="True"
                   IsVisible="{Binding HasError}"
                   BackgroundColor="#ffe6e6">
                <Label Text="{Binding ErrorMessage}"
                       FontSize="12" TextColor="#dc3545" LineBreakMode="WordWrap" />
            </Frame>

            <!-- Divider -->
            <BoxView Color="#e0e0e0" HeightRequest="1" />

            <!-- Queue List Section -->
            <Label Text="🎵 Hàng Đợi Phát"
                   FontSize="16" FontAttributes="Bold" />

            <!-- Queue Items -->
            <CollectionView ItemsSource="{Binding AudioQueue}"
                           SelectionMode="Single">
                <CollectionView.EmptyView>
                    <StackLayout Padding="20" Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="📭 Hàng đợi trống"
                               FontSize="14" FontAttributes="Bold" />
                        <Label Text="Quét QR hoặc vào gần POI để thêm thuyết minh"
                               FontSize="11" TextColor="#666" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="#e0e0e0" CornerRadius="10" Padding="12"
                               HasShadow="False">
                            <StackLayout Spacing="6">
                                <!-- POI Name -->
                                <Label Text="{Binding PoiName}"
                                       FontSize="14" FontAttributes="Bold" />

                                <!-- Language & Duration -->
                                <StackLayout Orientation="Horizontal" Spacing="15">
                                    <StackLayout Spacing="2">
                                        <Label Text="Ngôn ngữ" FontSize="10" TextColor="#999" />
                                        <Label Text="{Binding LanguageCode}"
                                               FontSize="11" TextColor="#666" />
                                    </StackLayout>
                                    <StackLayout Spacing="2">
                                        <Label Text="Thời lượng" FontSize="10" TextColor="#999" />
                                        <Label Text="{Binding DurationInSeconds, StringFormat='{0}s'}"
                                               FontSize="11" TextColor="#666" />
                                    </StackLayout>
                                </StackLayout>

                                <!-- Remove Button -->
                                <Button Text="❌ Xóa" FontSize="11"
                                        BackgroundColor="#dc3545" TextColor="White"
                                        Padding="8,4"
                                        CornerRadius="5"
                                        HorizontalOptions="Start" />
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Clear Queue Button -->
            <Button Text="🗑️ Xóa Toàn Bộ Hàng Đợi"
                    Command="{Binding ClearQueueCommand}"
                    BackgroundColor="#dc3545" TextColor="White"
                    CornerRadius="10" Padding="10" />

            <!-- Playback Stats -->
            <Frame BorderColor="#17a2b8" CornerRadius="10" Padding="12" HasShadow="True">
                <StackLayout Spacing="6">
                    <Label Text="📊 Thống Kê"
                           FontSize="13" FontAttributes="Bold" />
                    <StackLayout Orientation="Horizontal" Spacing="20">
                        <StackLayout Spacing="2">
                            <Label Text="Đang Phát" FontSize="10" TextColor="#999" />
                            <Label Text="{Binding IsPlaying, StringFormat='{0}'}"
                                   FontSize="11" FontAttributes="Bold" />
                        </StackLayout>
                        <StackLayout Spacing="2">
                            <Label Text="Tiến Độ" FontSize="10" TextColor="#999" />
                            <Label Text="{Binding PlaybackProgress, StringFormat='{0:P0}'}"
                                   FontSize="11" FontAttributes="Bold" />
                        </StackLayout>
                    </StackLayout>
                </StackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
