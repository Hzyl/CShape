<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioGuide.App.Views.QrScannerPage"
             Title="🔲 Quét QR Code"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <!-- Instruction -->
            <Frame BorderColor="#512BD4" CornerRadius="10" Padding="12" HasShadow="True">
                <StackLayout Spacing="8">
                    <Label Text="📖 Hướng Dẫn"
                           FontSize="14" FontAttributes="Bold" />
                    <Label Text="Nhấn nút 'Quét QR' để mở camera và quét mã QR tại các điểm du lịch."
                           FontSize="12" TextColor="#666" LineBreakMode="WordWrap" />
                    <Label Text="Ứng dụng sẽ tự động tải thông tin điểm du lịch và thêm thuyết minh vào hàng đợi."
                           FontSize="12" TextColor="#666" LineBreakMode="WordWrap" />
                </StackLayout>
            </Frame>

            <!-- Scanner Status -->
            <Frame BorderColor="#17a2b8" CornerRadius="10" Padding="12" HasShadow="True"
                   IsVisible="{Binding IsScanning}">
                <StackLayout Spacing="8">
                    <Label Text="🎥 Trạng Thái"
                           FontSize="14" FontAttributes="Bold" />
                    <StackLayout Orientation="Horizontal" Spacing="10">
                        <ActivityIndicator IsRunning="True" Color="#17a2b8" />
                        <Label Text="{Binding ScanningMessage}" VerticalTextAlignment="Center" />
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Error Message -->
            <Frame BorderColor="#dc3545" CornerRadius="10" Padding="12"
                   HasShadow="True"
                   IsVisible="{Binding HasError}"
                   BackgroundColor="#ffe6e6">
                <StackLayout Spacing="5">
                    <Label Text="❌ Lỗi"
                           FontSize="13" FontAttributes="Bold" TextColor="#dc3545" />
                    <Label Text="{Binding ErrorMessage}"
                           FontSize="12" TextColor="#666" LineBreakMode="WordWrap" />
                </StackLayout>
            </Frame>

            <!-- Camera Placeholder -->
            <Frame BorderColor="#999" CornerRadius="10" Padding="0" HasShadow="True"
                   HeightRequest="300"
                   IsVisible="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}">
                <StackLayout Padding="20" Spacing="20" VerticalOptions="CenterAndExpand"
                            HorizontalOptions="CenterAndExpand">
                    <Label Text="📷" FontSize="60" HorizontalTextAlignment="Center" />
                    <Label Text="Camera sẽ mở tại đây"
                           FontSize="14" HorizontalTextAlignment="Center" TextColor="#666" />
                </StackLayout>
            </Frame>

            <!-- Scan Result -->
            <Frame BorderColor="#28a745" CornerRadius="10" Padding="12"
                   HasShadow="True"
                   IsVisible="{Binding HasScanResult}"
                   BackgroundColor="#e6ffe6">
                <StackLayout Spacing="8">
                    <Label Text="✅ Kết Quả Quét"
                           FontSize="14" FontAttributes="Bold" TextColor="#28a745" />
                    <Label Text="{Binding ScanResultMessage}"
                           FontSize="12" TextColor="#333" LineBreakMode="WordWrap" />
                    <Label Text="{Binding ScannedQrData}"
                           FontSize="10" TextColor="#666" LineBreakMode="TailTruncation"
                           FontFamily="Courier" />
                </StackLayout>
            </Frame>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Scan QR Button -->
                <Button Text="📷 Quét QR"
                        Command="{Binding ScanQrCodeCommand}"
                        BackgroundColor="#512BD4" TextColor="White"
                        CornerRadius="10" Padding="10"
                        Grid.Column="0"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InvertedBoolConverter}}" />

                <!-- Play QR POI Audio -->
                <Button Text="🎵 Phát"
                        Command="{Binding PlayQrPoiAudioCommand}"
                        BackgroundColor="#28a745" TextColor="White"
                        CornerRadius="10" Padding="10"
                        Grid.Column="1"
                        IsEnabled="{Binding HasScanResult}" />
            </Grid>

            <!-- Camera Permission Notice (for iOS) -->
            <Label Text="💡 Lưu ý: Trên iOS, bạn sẽ được yêu cầu cho phép truy cập camera."
                   FontSize="11" TextColor="#666" LineBreakMode="WordWrap" />

            <!-- Testing Options (Debug Only) -->
            <Expander IsExpanded="False"
                     IsVisible="{Binding }">
                <Expander.Header>
                    <Label Text="🔧 Tùy Chọn Testing (Debug)" FontSize="12" FontAttributes="Bold" />
                </Expander.Header>
                <StackLayout Spacing="10" Padding="10">
                    <Label Text="Quét từ file hình ảnh (để testing):"
                           FontSize="11" TextColor="#666" />
                    <!-- TODO: Add file picker button for testing -->
                    <Button Text="Chọn Hình Ảnh & Quét QR"
                            BackgroundColor="#6c757d" TextColor="White"
                            CornerRadius="10" Padding="10" />
                </StackLayout>
            </Expander>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
