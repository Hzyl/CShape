<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioGuide.App.Views.PoiDetailPage"
             Title="📋 Chi Tiết Địa Điểm"
             BackgroundColor="#f5f5f5">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <!-- POI Image -->
            <Image Source="{Binding PoiDetail.ImageUrl}"
                   Aspect="AspectFill" HeightRequest="250"
                   CornerRadius="15"
                   IsVisible="{Binding PoiDetail.ImageUrl, Converter={StaticResource NullToBoolConverter}}" />

            <!-- POI Name -->
            <Label Text="{Binding PoiDetail.Name}"
                   FontSize="24" FontAttributes="Bold" />

            <!-- Coordinates -->
            <Frame BorderColor="#512BD4" CornerRadius="10" Padding="12" HasShadow="True">
                <StackLayout Spacing="8">
                    <Label Text="📍 Vị Trí"
                           FontSize="14" FontAttributes="Bold" />
                    <Label Text="{Binding PoiDetail.Latitude, StringFormat='Vĩ độ: {0:F6}'}"
                           FontSize="11" TextColor="#666" />
                    <Label Text="{Binding PoiDetail.Longitude, StringFormat='Kinh độ: {0:F6}'}"
                           FontSize="11" TextColor="#666" />
                </StackLayout>
            </Frame>

            <!-- Audio Information -->
            <Frame BorderColor="#17a2b8" CornerRadius="10" Padding="12" HasShadow="True">
                <StackLayout Spacing="8">
                    <Label Text="🎧 Thuyết Minh Audio"
                           FontSize="14" FontAttributes="Bold" />
                    <Label Text="{Binding PoiDetail.LanguageCode, StringFormat='Ngôn ngữ: {0}'}"
                           FontSize="11" TextColor="#666" />
                    <Label Text="{Binding PoiDetail.DurationInSeconds, StringFormat='Thời lượng: {0} giây'}"
                           FontSize="11" TextColor="#666"
                           IsVisible="{Binding PoiDetail.DurationInSeconds, Converter={StaticResource NullToBoolConverter}}" />
                </StackLayout>
            </Frame>

            <!-- Language Fallback Warning -->
            <Frame BorderColor="#ff9500" CornerRadius="10" Padding="12"
                   HasShadow="True"
                   IsVisible="{Binding HasLanguageFallback}"
                   BackgroundColor="#fff9e6">
                <StackLayout Spacing="5">
                    <Label Text="⚠️ Thông Báo Ngôn Ngữ"
                           FontSize="13" FontAttributes="Bold" TextColor="#ff9500" />
                    <Label Text="{Binding FallbackMessage}"
                           FontSize="11" TextColor="#666" LineBreakMode="WordWrap" />
                </StackLayout>
            </Frame>

            <!-- Text Description -->
            <Frame BorderColor="#e0e0e0" CornerRadius="10" Padding="12" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📝 Mô Tả"
                           FontSize="14" FontAttributes="Bold" />
                    <Label Text="{Binding PoiDetail.TextDescription}"
                           FontSize="12" TextColor="#333"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <!-- POI Metadata -->
            <Frame BorderColor="#512BD4" CornerRadius="10" Padding="12" HasShadow="True">
                <StackLayout Spacing="8">
                    <Label Text="ℹ️ Thông Tin POI"
                           FontSize="14" FontAttributes="Bold" />
                    <StackLayout Orientation="Horizontal" Spacing="20">
                        <StackLayout Spacing="3">
                            <Label Text="Bán kính GPS" FontSize="10" TextColor="#999" />
                            <Label Text="{Binding PoiDetail.TriggerRadius, StringFormat='{0}m'}"
                                   FontSize="12" FontAttributes="Bold" />
                        </StackLayout>
                        <StackLayout Spacing="3">
                            <Label Text="Mức Ưu Tiên" FontSize="10" TextColor="#999" />
                            <Label Text="{Binding PoiDetail.Priority, StringFormat='{0}/10'}"
                                   FontSize="12" FontAttributes="Bold" TextColor="#ff9500" />
                        </StackLayout>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Cooldown Warning -->
            <Frame BorderColor="#dc3545" CornerRadius="10" Padding="12"
                   HasShadow="True"
                   IsVisible="{Binding IsInCooldown}"
                   BackgroundColor="#ffe6e6">
                <StackLayout Spacing="5">
                    <Label Text="⏳ Cooldown Chống Spam (5 phút)"
                           FontSize="13" FontAttributes="Bold" TextColor="#dc3545" />
                    <Label Text="{Binding CooldownMessage}"
                           FontSize="11" TextColor="#666" />
                </StackLayout>
            </Frame>

            <!-- Error Message -->
            <Frame BorderColor="#dc3545" CornerRadius="10" Padding="12"
                   HasShadow="True"
                   IsVisible="{Binding HasError}"
                   BackgroundColor="#ffe6e6">
                <Label Text="{Binding ErrorMessage}"
                       FontSize="12" TextColor="#dc3545" LineBreakMode="WordWrap" />
            </Frame>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Play Button -->
                <Button Text="🎵 Phát Thuyết Minh"
                        Command="{Binding PlayAudioCommand}"
                        BackgroundColor="#512BD4" TextColor="White"
                        CornerRadius="10" Padding="10"
                        Grid.Column="0"
                        IsEnabled="{Binding CanPlayAudio}" />

                <!-- Share Button -->
                <Button Text="📤 Chia Sẻ"
                        Command="{Binding SharePoiCommand}"
                        BackgroundColor="#17a2b8" TextColor="White"
                        CornerRadius="10" Padding="10"
                        Grid.Column="1" />
            </Grid>

            <!-- Loading Indicator -->
            <StackLayout Orientation="Horizontal" Spacing="10"
                        IsVisible="{Binding IsLoading}">
                <ActivityIndicator IsRunning="True" Color="#512BD4" />
                <Label Text="{Binding LoadingMessage}" VerticalTextAlignment="Center" />
            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
