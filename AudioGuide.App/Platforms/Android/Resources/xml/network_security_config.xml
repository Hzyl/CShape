<?xml version="1.0" encoding="utf-8"?>
<!--
File: AudioGuide.App/Platforms/Android/Resources/xml/network_security_config.xml

Cấu hình bảo mật mạng cho Android 8.0+
- Cho phép HTTP cho emulator (10.0.2.2)
- Cho phép HTTP cho localhost
- Yêu cầu HTTPS cho các domain khác (production)
-->
<network-security-config>
    <!--
    Cấu hình cho emulator và development
    Cho phép cleartext traffic cho IP emulator
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>

    <!--
    Cấu hình cho production domains
    Yêu cầu HTTPS cho tất cả các domain này
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.audioguidesystem.com</domain>
        <domain includeSubdomains="true">audioguidesystem.com</domain>
    </domain-config>

    <!--
    Cấu hình mặc định cho các domain khác
    Production: Yêu cầu HTTPS
    -->
    <default-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Tin tưởng các CA chứng chỉ hệ thống -->
            <certificates src="system" />
        </trust-anchors>
    </default-config>
</network-security-config>
