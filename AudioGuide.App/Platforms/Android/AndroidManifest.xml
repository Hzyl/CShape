<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
    AndroidManifest.xml cho MAUI Audio Guide Application

    CHÚ Ý QUAN TRỌNG:
    - usesCleartextTraffic="true" cho phép HTTP (không phải HTTPS)
    - Cần cho phép cleartext để kết nối tới 10.0.2.2:5000 trên emulator
    - Trong production, nên sử dụng HTTPS và đặt usesCleartextTraffic="false"
    -->

    <!--
    Yêu cầu cấp quyền GPS (Location)
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!--
    Yêu cầu cấp quyền mạng
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
    Yêu cầu cấp quyền microphone (không bắt buộc, nếu có tính năng ghi âm)
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!--
    Yêu cầu cấp quyền camera (cho quét QR Code)
    -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!--
    Yêu cầu cấp quyền viết lưu trữ (cho cache audio)
    -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!--
    Android 8.0+ - Background Location Updates
    -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <application
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name">

        <!--
        HƯỚNG DẪN CẤU HÌNH CLEARTEXT TRAFFIC:

        1. usesCleartextTraffic="true" cho phép ứng dụng kết nối HTTP

        2. Nếu muốn chi tiết hơn, tạo file network_security_config.xml:
           res/xml/network_security_config.xml

           <?xml version="1.0" encoding="utf-8"?>
           <network-security-config>
               <domain-config cleartextTrafficPermitted="true">
                   <domain includeSubdomains="true">10.0.2.2</domain>
                   <domain includeSubdomains="true">localhost</domain>
               </domain-config>
               <domain-config cleartextTrafficPermitted="false">
                   <domain includeSubdomains="true">example.com</domain>
               </domain-config>
           </network-security-config>

           Sau đó thêm vào <application>:
           android:networkSecurityConfig="@xml/network_security_config"

        3. Target API Level:
           - Android 8.0+ (API 26): Cleartext traffic bị vô hiệu hóa mặc định
           - Cần khai báo rõ ràng usesCleartextTraffic="true" để cho phép
           - Hoặc sử dụng network security config

        4. Production:
           - Luôn luôn sử dụng HTTPS
           - Đặt usesCleartextTraffic="false" hoặc xóa khai báo
        -->

    </application>

</manifest>
