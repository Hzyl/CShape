&lt;?xml version="1.0" encoding="UTF-8" ?&gt;
&lt;Shell
    x:Class="AudioGuide.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AudioGuide.App.Views"
    FlyoutBehavior="Disabled"&gt;

    &lt;!--
    Shell Style Configuration
    Định cấu hình các thuộc tính hiển thị của Shell (TabBar, navigation)
    --&gt;
    &lt;Shell.Resources&gt;
        &lt;ResourceDictionary&gt;
            &lt;Color x:Key="PrimaryColor"&gt;#512BD4&lt;/Color&gt;
            &lt;Color x:Key="SecondaryColor"&gt;#DFD8F7&lt;/Color&gt;

            &lt;Style x:Key="BaseStyle" TargetType="Element"&gt;
                &lt;Setter Property="Shell.BackgroundColor" Value="#ffffff" /&gt;
                &lt;Setter Property="Shell.ForegroundColor" Value="#512BD4" /&gt;
                &lt;Setter Property="Shell.TitleColor" Value="#000000" /&gt;
                &lt;Setter Property="Shell.DisabledColor" Value="#B4009E" /&gt;
                &lt;Setter Property="Shell.UnselectedColor" Value="#95919C" /&gt;
            &lt;/Style&gt;
        &lt;/ResourceDictionary&gt;
    &lt;/Shell.Resources&gt;

    &lt;!--
    TabBar - Navigation tabs ở dưới cùng
    --&gt;
    &lt;TabBar&gt;
        &lt;!-- Bản đồ &amp; POI Nearby --&gt;
        &lt;ShellContent
            Title="Bản đồ"
            Icon="map.png"
            ContentTemplate="{DataTemplate local:MapPage}"
            Route="MapPage" /&gt;

        &lt;!-- Quét QR Code --&gt;
        &lt;ShellContent
            Title="Quét QR"
            Icon="qrcode.png"
            ContentTemplate="{DataTemplate local:QrScannerPage}"
            Route="QrScannerPage" /&gt;

        &lt;!-- Trình phát audio --&gt;
        &lt;ShellContent
            Title="Phát nhạc"
            Icon="music.png"
            ContentTemplate="{DataTemplate local:AudioPlayerPage}"
            Route="AudioPlayerPage" /&gt;

        &lt;!-- Cài đặt --&gt;
        &lt;ShellContent
            Title="Cài đặt"
            Icon="settings.png"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" /&gt;
    &lt;/TabBar&gt;

    &lt;!--
    Định nghĩa namespace để sử dụng local pages
    --&gt;
    &lt;Shell.Resources&gt;
        &lt;ResourceDictionary&gt;
            &lt;x:String x:Key="AppName"&gt;Audio Guide&lt;/x:String&gt;
        &lt;/ResourceDictionary&gt;
    &lt;/Shell.Resources&gt;

&lt;/Shell&gt;
