# Vinh Khanh Audio Guide - Mobile App Configuration
# Copy this file to .env.local and update with your values

# Backend API URL
# Development: http://localhost:5000/api/v1
# Production: https://api.vinhkhanh.com/api/v1
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

# Vinh Khanh Location (default center for map)
# Default: Vinh Khanh street food area in Ho Chi Minh City
EXPO_PUBLIC_MAP_CENTER_LAT=10.7769
EXPO_PUBLIC_MAP_CENTER_LNG=106.6956

# Default zoom level for map
EXPO_PUBLIC_MAP_DEFAULT_ZOOM=15

# Geofencing trigger radius (meters) - can be overridden per POI
EXPO_PUBLIC_DEFAULT_GEOFENCE_RADIUS=50

# Audio playback settings
EXPO_PUBLIC_AUDIO_ENABLE_CACHE=true
EXPO_PUBLIC_AUDIO_CACHE_MAX_MB=300

# Analytics settings
EXPO_PUBLIC_ANALYTICS_BATCH_INTERVAL=60000  # milliseconds

# App environment (development, staging, production)
EXPO_PUBLIC_APP_ENV=development
