<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CShape.Maui.Pages.ToursPage"
             Title="Tours">

    <Grid RowDefinitions="Auto,*" Padding="16">
        <!-- Header -->
        <Label Grid.Row="0"
               Text="Available Tours"
               FontSize="24"
               FontAttributes="Bold"
               Margin="0,0,0,16"/>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="1"
                          IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          Color="#667eea"
                          Scale="1.5"/>

        <!-- Tours List -->
        <CollectionView Grid.Row="1"
                       ItemsSource="{Binding Tours}"
                       SelectionMode="Single"
                       SelectionChangedCommand="{Binding SelectTourCommand}"
                       SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}"
                       IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#667eea" CornerRadius="8" Padding="12" Margin="0">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*">
                            <Label Grid.Row="0"
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"/>
                            <Label Grid.Row="1"
                                   Text="{Binding DescriptionVi}"
                                   FontSize="14"
                                   Margin="0,8,0,0"
                                   LineBreakMode="TailTruncation"/>
                            <Label Grid.Row="2"
                                   Text="{Binding EstimatedDurationMinutes, StringFormat='{0} minutes'}"
                                   FontSize="12"
                                   TextColor="Gray"
                                   Margin="0,8,0,0"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Error Message -->
        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               FontSize="14"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"
               Margin="0,16"/>
    </Grid>
</ContentPage>
