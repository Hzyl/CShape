<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CShape.Maui.Pages.TourPlaybackPage"
             Title="Tour Playback">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">
        <!-- Tour Title -->
        <Label Grid.Row="0"
               Text="{Binding CurrentTour.Name}"
               FontSize="24"
               FontAttributes="Bold"
               Margin="0,0,0,16"/>

        <!-- POI Content -->
        <ScrollView Grid.Row="1">
            <StackLayout Spacing="16" Padding="0">
                <!-- POI Image -->
                <Frame BorderColor="#667eea" CornerRadius="8" Padding="0" HasShadow="True">
                    <Image Source="{Binding CurrentPoi.ImageUrls, Converter={StaticResource FirstImageConverter}}"
                           Aspect="AspectFill"
                           HeightRequest="300"/>
                </Frame>

                <!-- POI Name and Type -->
                <StackLayout Spacing="8">
                    <Label Text="{Binding CurrentPoi.Name}"
                           FontSize="20"
                           FontAttributes="Bold"/>
                    <Label Text="{Binding CurrentPoi.Type}"
                           FontSize="14"
                           TextColor="Gray"/>
                </StackLayout>

                <!-- Description -->
                <Label Text="{Binding CurrentPoi.DescriptionVi}"
                       FontSize="14"
                       Margin="0,8"/>

                <!-- Audio Button -->
                <Button Text="{Binding IsPlaying, StringFormat='{0:Playing...,Play Audio}'}"
                        Command="{Binding PlayAudioCommand}"
                        IsEnabled="{Binding IsPlaying, Converter={StaticResource InvertedBoolConverter}}"
                        Background="#667eea"
                        TextColor="White"
                        Padding="16,12"
                        CornerRadius="8"/>

                <!-- POI Index -->
                <Label Text="{Binding CurrentPoiIndex, StringFormat='Location {0} of '}{Binding TourPois.Count}"
                       FontSize="12"
                       TextColor="Gray"
                       HorizontalTextAlignment="Center"
                       Margin="0,16,0,0"/>
            </StackLayout>
        </ScrollView>

        <!-- Navigation Buttons -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,*"
              ColumnSpacing="8"
              Margin="0,16,0,0">
            <Button Grid.Column="0"
                    Text="← Previous"
                    Command="{Binding PreviousPoiCommand}"
                    Background="#764ba2"
                    TextColor="White"
                    Padding="16,12"
                    CornerRadius="8"/>
            <Button Grid.Column="1"
                    Text="Next →"
                    Command="{Binding NextPoiCommand}"
                    Background="#667eea"
                    TextColor="White"
                    Padding="16,12"
                    CornerRadius="8"/>
        </Grid>
    </Grid>
</ContentPage>
