<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CShape.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <TabBar>
        <ShellContent
            Title="Tours"
            Icon="icon_about.png"
            Route="tours"
            ContentTemplate="{DataTemplate local:ToursPage}" />
    </TabBar>

    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#667eea" Padding="20" HeightRequest="100">
            <Label Text="CShape Tours" FontSize="24" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Routes -->
    <ShellRoute Route="tour/{id}" ShellContent.ContentTemplate="{DataTemplate local:TourPlaybackPage}" />
</Shell>
