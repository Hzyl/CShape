<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="CShape.Maui.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:CShape.Maui.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBackgroundColor">White</Color>
            <Color x:Key="PrimaryColor">#667eea</Color>
            <Color x:Key="SecondaryColor">#764ba2</Color>

            <!-- Converters -->
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <converters:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmptyConverter"/>
            <converters:FirstImageConverter x:Key="FirstImageConverter"/>

            <Style TargetType="Page">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBackgroundColor}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
