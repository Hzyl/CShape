@using CShape.Shared.Models
@using CShape.Blazor.Services
@inject IAdminService AdminService

<div class="tour-management">
    <h3>Tours Management</h3>
    
    @if (isLoading)
    {
        <p><em>Loading tours...</em></p>
    }
    else
    {
        <button class="btn btn-primary mb-3" @onclick="ShowAddForm">
            + Create Tour
        </button>

        @if (tours.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>POIs</th>
                        <th>Status</th>
                        <th>Duration</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tour in tours)
                    {
                        <tr>
                            <td>@tour.Name</td>
                            <td>@tour.POIIds.Count</td>
                            <td>
                                <span class="badge bg-success">@tour.Status</span>
                            </td>
                            <td>@tour.EstimatedDurationMinutes min</td>
                            <td>
                                <button class="btn btn-sm btn-warning" @onclick="() => EditTour(tour)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteTour(tour.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No tours found.</p>
        }
    }

    @if (showForm)
    {
        <div class="modal d-block show" style="display: block;">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@(editingTour?.Id == null ? "Create Tour" : "Edit Tour")</h5>
                        <button type="button" class="btn-close" @onclick="CloseForm"></button>
                    </div>
                    <div class="modal-body">
                        <form>
                            <div class="mb-3">
                                <label class="form-label">Tour Name</label>
                                <input type="text" class="form-control" @bind="editingTour.Name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description (Vietnamese)</label>
                                <textarea class="form-control" @bind="editingTour.DescriptionVi" rows="3"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Status</label>
                                <select class="form-control" @bind="editingTour.Status">
                                    <option value="draft">Draft</option>
                                    <option value="published">Published</option>
                                    <option value="archived">Archived</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Estimated Duration (Minutes)</label>
                                <input type="number" class="form-control" @bind="editingTour.EstimatedDurationMinutes" />
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveTour">Save Tour</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }
</div>

@code {
    private List<Tour> tours = new();
    private bool isLoading = true;
    private bool showForm = false;
    private Tour editingTour = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTours();
    }

    private async Task LoadTours()
    {
        isLoading = true;
        tours = await AdminService.GetAllToursAsync();
        isLoading = false;
    }

    private void ShowAddForm()
    {
        editingTour = new Tour();
        showForm = true;
    }

    private void EditTour(Tour tour)
    {
        editingTour = tour;
        showForm = true;
    }

    private async Task SaveTour()
    {
        if (editingTour.Id == null)
        {
            await AdminService.CreateTourAsync(editingTour);
        }
        else
        {
            await AdminService.UpdateTourAsync(editingTour.Id, editingTour);
        }
        CloseForm();
        await LoadTours();
    }

    private async Task DeleteTour(string? id)
    {
        if (id != null && await AdminService.DeleteTourAsync(id))
        {
            await LoadTours();
        }
    }

    private void CloseForm()
    {
        showForm = false;
        editingTour = new();
    }
}
